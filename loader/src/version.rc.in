#define VERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
#define VERSION_STR "@PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0"

1 VERSIONINFO
 FILEVERSION VERSION
 PRODUCTVERSION VERSION
 FILEFLAGSMASK   0x17L
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x4L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
	BLOCK "StringFileInfo"
	BEGIN
		BLOCK "040904B0"
		BEGIN
			VALUE "Comments", "Lego Game Mod Loader"
			VALUE "CompanyName", "BlueBrick Development Team"
			VALUE "FileDescription", "Lego game mod loader."
			VALUE "FileVersion", VERSION_STR
			VALUE "InternalName", "BlueBrick"
			VALUE "LegalCopyright", "2024 The BlueBrick Team"
			VALUE "OriginalFileName", "BlueBrick.dll"
			VALUE "ProductName", "BlueBrick"
			VALUE "ProductVersion", VERSION_STR
		END
	END
	BLOCK "VarFileInfo"
	BEGIN
		VALUE "Translation", 0x409, 1200
	END
END